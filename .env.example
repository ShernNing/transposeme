# Copy to .env and fill in. Do NOT commit .env (gitignored).

# Backend API base URL (leave blank to use same-origin / dev proxy).
# For the desktop build this is ignored — `vite build --mode electron` pins it to
# the locally-spawned backend (http://localhost:4000). See server/YOUTUBE.md.
VITE_API_BASE_URL=http://localhost:4000

# ChordVault integration (Supabase anon key — safe to expose in client)
VITE_CHORDVAULT_SUPABASE_URL=
VITE_CHORDVAULT_SUPABASE_KEY=
VITE_CHORDVAULT_APP_URL=
